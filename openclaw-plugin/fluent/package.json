{
  "name": "fluent-openclaw-oss-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bundled Fluent open-source runtime helper package for OpenClaw skills, local auth, and MCP setup.",
  "author": {
    "name": "Fluent",
    "email": "alex@example.invalid",
    "url": "https://mcp.meetfluent.app"
  },
  "homepage": "https://mcp.meetfluent.app",
  "repository": "https://github.com/shaner-git/fluent-oss",
  "license": "MIT",
  "keywords": [
    "fluent",
    "meals",
    "health",
    "style",
    "openclaw",
    "plugin",
    "personal-mcp"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "assets",
    "skills",
    "src",
    ".mcp.hosted.json",
    ".mcp.json",
    ".mcp.local.json",
    ".mcp.oss.json",
    "index.js",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "x-fluent": {
    "artifactKind": "oss-bundled-openclaw-helper",
    "packagingDecision": "oss-embedded-openclaw-bundle-is-a-distinct-helper-package",
    "standalonePackageName": "fluent-openclaw",
    "standalonePackageRepository": "https://github.com/shaner-git/fluent-openclaw",
    "versionPolicy": "Tracks bundled Fluent open-source runtime helper revisions and is not the published fluent-openclaw package line.",
    "backendModesStatus": "plugin-managed-auth-beta",
    "backendModes": ["hosted", "local"],
    "legacyBackendModes": ["hosted", "local"],
    "deploymentTracks": ["cloud", "oss"],
    "defaultDeploymentTrack": "cloud",
    "minimumContractVersion": "2026-04-20.fluent-core-v1.37",
    "requiredHostedScopes": ["meals:read", "meals:write", "health:read", "health:write", "style:read", "style:write", "offline_access"],
    "pluginManagedAuth": true
  }
}
