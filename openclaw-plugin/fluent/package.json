{
  "name": "fluent-openclaw-oss-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bundled OpenClaw helper package shipped with Fluent open-source exports; not the published fluent-openclaw package.",
  "author": {
    "name": "Fluent"
  },
  "homepage": "https://github.com/shaner-git/fluent-oss/blob/main/docs/fluent-oss.md",
  "repository": "https://github.com/shaner-git/fluent-oss",
  "files": [
    "assets",
    "skills",
    "src",
    ".mcp.hosted.json",
    ".mcp.json",
    ".mcp.local.json",
    ".mcp.oss.json",
    "index.js",
    "openclaw.plugin.json",
    "README.md"
  ],
  "license": "MIT",
  "keywords": [
    "fluent",
    "meals",
    "health",
    "style",
    "openclaw",
    "plugin",
    "personal-mcp"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "x-fluent": {
    "artifactKind": "oss-bundled-openclaw-helper",
    "packagingDecision": "oss-embedded-openclaw-bundle-is-a-distinct-helper-package",
    "publishedPackageName": "fluent-openclaw",
    "publishedPackageRepository": "https://github.com/shaner-git/fluent-openclaw",
    "helperVersionPolicy": "Tracks Fluent open-source bundled-helper revisions and is not the published fluent-openclaw package line.",
    "backendModesStatus": "plugin-managed-auth-beta",
    "backendModes": [
      "hosted",
      "local"
    ],
    "legacyBackendModes": [
      "hosted",
      "local"
    ],
    "deploymentTracks": [
      "cloud",
      "oss"
    ],
    "defaultDeploymentTrack": "oss",
    "minimumContractVersion": "2026-04-26.fluent-core-v1.48",
    "requiredHostedScopes": [
      "meals:read",
      "meals:write",
      "health:read",
      "health:write",
      "style:read",
      "style:write",
      "offline_access"
    ],
    "pluginManagedAuth": true
  }
}
